    </div>
  </div>

  <table id="report">
    <thead>
      <tr>
        <th></th>
        <th>Day</th>
        <th>Work Details</th>
        <th>Hours</th>
        <th class="no-copy"></th>
      </tr>
    </thead>
    <tbody>
  #{rows_html}    </tbody>
  </table>
