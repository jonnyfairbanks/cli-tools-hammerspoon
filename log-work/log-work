  <script>
    function rowsToHtml(rows) {
      const t = document.createElement("table");
      const tb = document.createElement("tbody");
      rows.forEach(tr => {
        const clone = tr.cloneNode(true);
        clone.querySelectorAll(".no-copy").forEach(n => n.remove());
        clone.querySelectorAll("[contenteditable]").forEach(n => n.removeAttribute("contenteditable"));
        tb.appendChild(clone);
      });
      t.appendChild(tb);
      return t.outerHTML;
    }

    function rowsToText(rows) {
      return rows.map(tr => {
        const tds = Array.from(tr.children);
        return tds.map(td => {
          if (td.classList.contains("no-copy")) return null;
          const raw = (td.classList.contains("col-details") ? td.innerText : td.textContent).trim();
          if (td.classList.contains("col-details")) {
            return '"' + raw.replace(/"/g, '""') + '"';
          }
          return raw;
        }).filter(v => v !== null).join("\\t");
      }).join("\\n");
    }

    async function copyHtml(html, text, btn) {
      try {
        const item = new ClipboardItem({
          "text/html":  new Blob([html], { type: "text/html" }),
          "text/plain": new Blob([text], { type: "text/plain" })
        });
        await navigator.clipboard.write([item]);
        flash(btn, "Copied ✓");
      } catch (err) {
        try { await navigator.clipboard.writeText(text); flash(btn, "Copied ✓"); }
        catch (e2) { flash(btn, "Copy failed", true); console.error(e2); }
      }
    }

    function flash(btn, msg, isError = false) {
      const original = btn.textContent;
      btn.textContent = msg;
      if (!isError) btn.classList.add("copied");
      setTimeout(() => { btn.textContent = original; btn.classList.remove("copied"); }, 1400);
    }

    document.querySelectorAll("[data-copy-row]").forEach(btn => {
      btn.addEventListener("click", () => {
        const tr = btn.closest("tr");
        copyHtml(rowsToHtml([tr]), rowsToText([tr]), btn);
      });
    });

    function rowsInDayRange(start, end) {
      return Array.from(document.querySelectorAll("#report tbody tr")).filter(tr => {
        const dayCell = tr.querySelector(".col-day");
        if (!dayCell) return false;
        const day = parseInt(dayCell.textContent.trim(), 10);
        return Number.isFinite(day) && day >= start && day <= end;
      });
    }

    function wireRangeButton(id, start, end) {
      const btn = document.getElementById(id);
      if (!btn) return;
      btn.addEventListener("click", () => {
        const rows = rowsInDayRange(start, end);
        copyHtml(rowsToHtml(rows), rowsToText(rows), btn);
      });
    }

    wireRangeButton("copy-1-15", 1, 15);
    wireRangeButton("copy-16-end", 16, 31);

    const copyAllBtn = document.getElementById("copy-all");
    if (copyAllBtn) {
      copyAllBtn.addEventListener("click", () => {
        const rows = Array.from(document.querySelectorAll("#report tbody tr"));
        copyHtml(rowsToHtml(rows), rowsToText(rows), copyAllBtn);
      });
    }
  </script>
  </body>
  </html>
HTML

out_path = "/tmp/log-work-#{format("%04d-%02d", year, month)}.html"
File.write(out_path, html)

# ──────────────────────────────────────────────────────────────────────────────
# Output

total_commits = days_data.sum { |d| d[:commits].length }
total_hours = days_data.sum { |d| d[:hours] || 0.0 }
top_day = days_data.max_by { |d| d[:commits].length }

summary = {
  month: format("%04d-%02d", year, month),
  month_label: month_label,
  repo: repo,
  author: AUTHOR,
  html_path: out_path,
  totals: {
    days_with_activity: active_days.length,
    days_empty: empty_days.length,
    total_commits: total_commits,
    total_hours: total_hours.round(2),
    busiest_day: top_day && top_day[:commits].any? ? { day: top_day[:day], commits: top_day[:commits].length } : nil
  },
  clockify: { ok: clockify_result[:ok], error: clockify_result[:error] },
  weekly_cap: WEEKLY_CAP,
  hourly_rate: HOURLY_RATE,
  paycheck: {
    period_1: { label: period_1_label, hours: period_1_hours, pay: (period_1_hours * HOURLY_RATE).round(2) },
    period_2: { label: period_2_label, hours: period_2_hours, pay: (period_2_hours * HOURLY_RATE).round(2) },
    total_hours: total_paycheck_hours,
    total_pay: (total_paycheck_hours * HOURLY_RATE).round(2)
  },
  weeks: weeks_data.map { |w|
    {
      start: w[:dates].first.strftime("%Y-%m-%d"),
      end: w[:dates].last.strftime("%Y-%m-%d"),
      total_hours: w[:total],
      status: w[:status].to_s
    }
  },
  active_days: active_days,
  empty_days: empty_days,
  days: days_data.map { |d|
    {
      day: d[:day],
      iso: d[:iso],
      hours: d[:hours],
      hours_raw: d[:hours_raw],
      defaults_applied: d[:defaults_applied].map(&:to_s),
      commits: d[:commits].map { |c| { sha: c[:sha], subject: c[:subject], bullet: commit_to_bullet(c[:subject]) } }
    }
  }
}

if options[:emit_json]
  puts JSON.pretty_generate(summary)
else
  warn "Wrote #{out_path}"
  warn "  #{active_days.length} days with activity, #{empty_days.length} empty"
  warn "  #{total_commits} commits, #{format("%.2f", total_hours)} hours"
  warn "  Clockify: #{clockify_result[:ok] ? "ok" : "FAILED — #{clockify_result[:error]}"}"
  puts out_path
end

if options[:open]
  if CHROME_PROFILE_ACCOUNT && File.executable?(OPEN_PROFILE)
    system(OPEN_PROFILE, "-p", CHROME_PROFILE_ACCOUNT, out_path)
  else
    system("/usr/bin/open", out_path)
  end
end
