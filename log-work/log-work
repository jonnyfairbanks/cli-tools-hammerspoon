  </style>
  </head>
  <body>
  <header>
    <div>
      <h1>Log Work — #{month_label}</h1>
      <div class="subtitle">#{sheet_link_html}</div>
    </div>
    <div class="header-buttons">
      <button class="copy-btn copy-all-btn" id="copy-1-15">Copy 1–15</button>
