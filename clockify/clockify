# ──────────────────────────────────────────────────────────────────────────────
# Status cache (consumed by mac menu bar tools — Hammerspoon/xbar/SwiftBar/etc.)

def write_cache(data)
  FileUtils_mkdir_p(File.dirname(CACHE_PATH))
  File.write(CACHE_PATH, JSON.generate(data))
rescue StandardError => e
  warn "warning: could not write cache (#{e.message})"
end

# Patch updates onto the existing cache (preserves the summary block when
# start/stop change only the running state).
def merge_cache(updates)
  existing = read_cache || {}
  write_cache(existing.merge(updates))
end

def FileUtils_mkdir_p(dir)
  # Avoid `require "fileutils"` for a one-liner. Walk up and mkdir each level.
  return if File.directory?(dir)
  FileUtils_mkdir_p(File.dirname(dir))
  Dir.mkdir(dir) unless File.directory?(dir)
end

def read_cache
  return nil unless File.exist?(CACHE_PATH)
  JSON.parse(File.read(CACHE_PATH))
rescue StandardError
  nil
end

def cache_for_running(running, workspace_id)
  project_id    = running["projectId"]
  project_label = project_id ? fetch_project_by_id(workspace_id, project_id)["name"] : nil
  {
    "running"     => true,
    "description" => running["description"].to_s,
    "project"     => project_label,
    "started_at"  => running["timeInterval"]["start"],
    "fetched_at"  => iso8601_z(Time.now)
  }
end

def cache_for_idle
  { "running" => false, "fetched_at" => iso8601_z(Time.now) }
end

# ──────────────────────────────────────────────────────────────────────────────
# Action helpers (shared by start / stop / punch)

def start_entry(workspace_id, project_name, description)
  project = fetch_project(workspace_id, project_name)
  entry = http_post("workspaces/#{workspace_id}/time-entries", {
    start:       iso8601_z(Time.now),
    description: description,
    projectId:   project["id"],
    billable:    true
  })
  started_at = Time.parse(entry["timeInterval"]["start"]).getlocal.strftime("%H:%M")
  desc_show  = description.empty? ? "(no description)" : description
  puts "▶ Started #{desc_show} — #{project["name"]} at #{started_at}"
  merge_cache({
    "running"     => true,
    "description" => description,
    "project"     => project["name"],
    "started_at"  => entry["timeInterval"]["start"],
    "fetched_at"  => iso8601_z(Time.now)
  })
end

def stop_entry(workspace_id, user_id, running)
  http_patch("workspaces/#{workspace_id}/user/#{user_id}/time-entries", {
    end: iso8601_z(Time.now)
  })
  start_t       = Time.parse(running["timeInterval"]["start"]).getlocal
  end_t         = Time.now
  duration_secs = end_t - start_t
  desc          = running["description"].to_s
  desc_show     = desc.empty? ? "(no description)" : desc
  puts "■ Stopped #{desc_show} — #{humanize_duration(duration_secs)} " \
       "(#{start_t.strftime("%H:%M")} → #{end_t.strftime("%H:%M")})"
  merge_cache(cache_for_idle.merge({ "description" => nil, "project" => nil, "started_at" => nil }))
end

def prompt_yes_no(question)
  $stdout.print "#{question} "
  $stdout.flush
  input = $stdin.gets
  return false if input.nil?
  answer = input.strip.downcase
  answer.empty? || answer == "y" || answer == "yes"
end

# ──────────────────────────────────────────────────────────────────────────────
# Subcommand: start

def cmd_start
  options = { project: PROJECT_NAME, description: "" }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: clockify start [-p PROJECT] [-d DESCRIPTION]"
    opts.on("-p", "--project NAME",     "Project name (default: #{PROJECT_NAME})")  { |v| options[:project]     = v }
    opts.on("-d", "--description TEXT", "Entry description (default: empty)")       { |v| options[:description] = v }
    opts.on("-h", "--help",             "Show this help")                           { puts opts; exit 0 }
  end

  begin
    parser.parse!
  rescue OptionParser::ParseError => e
    warn "error: #{e.message}"
    warn parser
    exit 2
  end

  user         = fetch_user
  workspace_id = user.fetch("defaultWorkspace")
  user_id      = user.fetch("id")

  if (running = find_running_entry(workspace_id, user_id))
    started   = Time.parse(running["timeInterval"]["start"]).getlocal.strftime("%H:%M")
    desc      = running["description"].to_s
    desc_show = desc.empty? ? "(no description)" : desc.inspect
    warn "error: an entry is already running — started at #{started}, description #{desc_show}"
    warn "Run `clockify stop` first."
    exit 1
  end

  start_entry(workspace_id, options[:project], options[:description])
end

# ──────────────────────────────────────────────────────────────────────────────
# Subcommand: stop

def cmd_stop
  parser = OptionParser.new do |opts|
    opts.banner = "Usage: clockify stop"
    opts.on("-h", "--help", "Show this help") { puts opts; exit 0 }
  end

  begin
    parser.parse!
  rescue OptionParser::ParseError => e
    warn "error: #{e.message}"
    warn parser
    exit 2
  end

  user         = fetch_user
  workspace_id = user.fetch("defaultWorkspace")
  user_id      = user.fetch("id")

  running = find_running_entry(workspace_id, user_id)
  unless running
    warn "warning: no entry currently running"
    exit 1
  end

  stop_entry(workspace_id, user_id, running)
end

# ──────────────────────────────────────────────────────────────────────────────
# Subcommand: punch (smart toggle — confirms then starts or stops)

def cmd_punch
  options = { project: PROJECT_NAME, description: "", yes: false }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: clockify punch [-p PROJECT] [-d DESCRIPTION] [-y]"
    opts.on("-p", "--project NAME",     "Project name if starting (default: #{PROJECT_NAME})") { |v| options[:project]     = v }
    opts.on("-d", "--description TEXT", "Description if starting (default: empty)")            { |v| options[:description] = v }
    opts.on("-y", "--yes",              "Auto-confirm — toggle without prompting")             { options[:yes] = true }
    opts.on("-h", "--help",             "Show this help")                                      { puts opts; exit 0 }
  end

  begin
    parser.parse!
  rescue OptionParser::ParseError => e
    warn "error: #{e.message}"
    warn parser
    exit 2
  end

  user         = fetch_user
  workspace_id = user.fetch("defaultWorkspace")
  user_id      = user.fetch("id")

  running = find_running_entry(workspace_id, user_id)

  if running
    if options[:yes]
      stop_entry(workspace_id, user_id, running)
    else
      start_t       = Time.parse(running["timeInterval"]["start"]).getlocal
      duration_secs = Time.now - start_t
      desc          = running["description"].to_s
      desc_show     = desc.empty? ? "(no description)" : desc.inspect
      project_id    = running["projectId"]
      project_label = project_id ? fetch_project_by_id(workspace_id, project_id)["name"] : "(no project)"

      question = "▶ #{desc_show} — #{project_label}, started #{start_t.strftime("%H:%M")} " \
                 "(#{humanize_duration(duration_secs)}). Stop? [Y/n]"
      stop_entry(workspace_id, user_id, running) if prompt_yes_no(question)
    end
  else
    if options[:yes]
      start_entry(workspace_id, options[:project], options[:description])
    else
      desc      = options[:description]
      desc_show = desc.empty? ? "(no description)" : desc.inspect
      question  = "No entry running. Start #{desc_show} on #{options[:project]}? [Y/n]"
      start_entry(workspace_id, options[:project], options[:description]) if prompt_yes_no(question)
    end
  end
end

# ──────────────────────────────────────────────────────────────────────────────
# Subcommand: status (cached, designed for mac menu bar polling)

def cmd_status
  options = { json: false, mode: :auto }  # :auto | :refresh | :no_refresh

  parser = OptionParser.new do |opts|
    opts.banner = <<~USAGE
      Usage: clockify status [--json] [--refresh | --no-refresh]

      Print current Clockify status. Reads from cache at #{CACHE_PATH}
      and auto-refreshes from the API if older than #{CACHE_TTL / 60} minutes.

      Flags:
    USAGE
    opts.on(      "--json",        "Emit JSON (for menu bar parsing)") { options[:json] = true }
    opts.on("-r", "--refresh",     "Force API call, ignore cache TTL") { options[:mode] = :refresh }
    opts.on(      "--no-refresh",  "Read cache only, never hit API")   { options[:mode] = :no_refresh }
    opts.on("-h", "--help",        "Show this help")                   { puts opts; exit 0 }
  end

  begin
    parser.parse!
  rescue OptionParser::ParseError => e
    warn "error: #{e.message}"
    warn parser
    exit 2
  end

  cached = read_cache
  fresh  = cache_fresh?(cached)
  data =
    case options[:mode]
    when :no_refresh then cached
    when :refresh    then refresh_status
    else (fresh ? cached : refresh_status)
    end

  render_status(data, options[:json])
end

def cache_fresh?(cached)
  return false unless cached && cached["fetched_at"]
  (Time.now - Time.parse(cached["fetched_at"])) < CACHE_TTL
rescue StandardError
  false
end

def refresh_status
  user         = fetch_user
  workspace_id = user.fetch("defaultWorkspace")
  user_id      = user.fetch("id")
  running      = find_running_entry(workspace_id, user_id)
  data         = running ? cache_for_running(running, workspace_id) : cache_for_idle

  # Bake week + paycheck totals into the cache so the menu bar can read them
  # without hitting the API itself. Failures here shouldn't break the status
  # refresh — keep the running/idle data intact and move on.
  begin
    project = fetch_project(workspace_id, PROJECT_NAME)
    data.merge!(compute_summary(workspace_id, user_id, project["id"]))
  rescue ClockifyError => e
    warn "warning: could not compute summary (#{e.message})"
  end

  write_cache(data)
  data
end

def render_status(data, as_json)
  if as_json
    puts JSON.generate(data || { "running" => false })
    return
  end

  if data.nil?
    puts "■ unknown (no cache)"
    return
  end

  if data["running"]
    elapsed   = Time.now - Time.parse(data["started_at"])
    desc      = data["description"].to_s
    desc_show = desc.empty? ? "(no description)" : desc
    puts "▶ #{desc_show} — #{humanize_duration(elapsed)}"
  else
    puts "■ idle"
  end
end

# ──────────────────────────────────────────────────────────────────────────────
# Subcommand: help

def cmd_help
  puts <<~USAGE
    clockify — Clockify time-tracking CLI

    Usage:
      clockify                                              Show this help
      clockify log   [-m MM] [-y YYYY] [-d DD] [--json]     Report hours
      clockify start [-p PROJECT] [-d DESCRIPTION]          Clock in
      clockify stop                                         Clock out
      clockify punch [-p PROJECT] [-d DESCRIPTION] [-y]     Smart toggle: prompts to start or stop (-y to skip prompt)
      clockify status [--json] [--refresh | --no-refresh]   Cached status (for mac menu bar)
      clockify day   [--json]                               Today's hour total
      clockify week  [--json]                               Current-week hour total + paycheck halves
      clockify open                                         Open https://app.clockify.me/tracker

    Configured project: #{PROJECT_NAME} (override with -p or $CLOCKIFY_PROJECT)

    Run any subcommand with -h for its own flags.
  USAGE
end

# ──────────────────────────────────────────────────────────────────────────────
# Entry point

def main
  case ARGV.first
  when nil, "-h", "--help" then cmd_help
  when "log"   then ARGV.shift; cmd_log
  when "start" then ARGV.shift; cmd_start
  when "stop"  then ARGV.shift; cmd_stop
  when "punch"  then ARGV.shift; cmd_punch
  when "status" then ARGV.shift; cmd_status
  when "day"    then ARGV.shift; cmd_day
  when "week"   then ARGV.shift; cmd_week
  when "open"   then ARGV.shift; cmd_open
  else
    warn "error: unknown subcommand: #{ARGV.first.inspect}"
    warn "Run `clockify --help` to see available commands."
    exit 2
  end
rescue ClockifyError => e
  warn "error: #{e.message}"
  exit 1
rescue Errno::ECONNREFUSED, SocketError, Net::OpenTimeout, Net::ReadTimeout => e
  warn "network error: #{e.message}"
  exit 1
end

main
